    "activityBar.inactiveForeground": "#2a2f36",
    "activityBar.border": "#98a3b3",
    "activityBarBadge.background": "#2a2f36",
    "activityBarBadge.foreground": "#b4bcc8",

    "sideBar.background": "#aab2be",
    "sideBar.foreground": "#1b1f24",
