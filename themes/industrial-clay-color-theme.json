    "button.secondaryHoverBackground": "#7f8a9a",

    "dropdown.background": "#aab2be",
    "dropdown.border": "#98a3b3",
    "dropdown.foreground": "#1b1f24",

    "input.background": "#aab2be",
    "input.border": "#98a3b3",
    "input.foreground": "#1b1f24",
    "input.placeholderForeground": "#2a2f36",

    "badge.foreground": "#b4bcc8",
    "badge.background": "#2a2f36",

    "progressBar.background": "#2a2f36",

    "activityBar.background": "#aab2be",
